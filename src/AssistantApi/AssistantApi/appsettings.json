{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "AssistantApi.Services.DocumentValidation": "Debug",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/assistant-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Ollama": {
    "BaseUrl": "http://ollama:11434",
    "Model": "qwen2.5:7b",
    "EmbeddingModel": "bge-m3",
    "Temperature": 0.7,
    "TopP": 0.9
  },
  "Qdrant": {
    "Host": "qdrant",
    "Port": 6333,
    "CollectionName": "knowledge_base"
  },
  "Cors": {
    "ChatUiOrigin": "http://localhost:5173"
  },
  "DocumentValidation": {
    "TemplateNotFoundMessage": "Эталонный шаблон не найден. Обратитесь к специалисту.",
    "UnsupportedFormatMessage": "Поддерживаются только форматы DOCX и PDF.",
    "EmptyFileMessage": "Файл не передан.",
    "TextExtractionFailedMessage": "Не удалось извлечь текст из файла. Проверьте качество файла или формат содержимого.",
    "PdfOcrRecommendationMessage": "Для PDF-сканов требуется OCR-модуль. Подключите OCR и повторите проверку.",
    "OcrFailedMessage": "OCR не смог распознать текст из PDF. Требуется проверка качества скана.",
    "Ocr": {
      "Enabled": true,
      "Command": "ocrmypdf",
      "ArgumentsTemplate": "--force-ocr --language {lang} {input} {output}",
      "Language": "rus+eng",
      "TimeoutSeconds": 180,
      "MinExtractedTextLength": 120
    },
    "Ml": {
      "Enabled": true,
      "ConfidenceThreshold": 0.55,
      "EnableSummary": true,
      "MaxInputChars": 4500
    },
    "Templates": [
      {
        "DisplayName": "приказ",
        "DetectionKeywords": ["приказ"],
        "RequiredKeywords": ["приказ", "номер", "дата", "основан", "подпись"]
      },
      {
        "DisplayName": "доверенность",
        "DetectionKeywords": ["доверенн", "доверител", "представител"],
        "RequiredKeywords": ["доверенность", "доверител", "представител", "паспорт", "дата", "подпись"]
      },
      {
        "DisplayName": "договор",
        "DetectionKeywords": ["договор", "сторон", "предмет"],
        "RequiredKeywords": ["договор", "предмет", "сторон", "срок", "подпись"]
      }
    ]
  },
  "AllowedHosts": "*"
}
